# Supabase (REQUIRED for local dev and Vercel)
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (optional, defaults to https://artspire.in)
VITE_SITE_URL=https://your-domain.com

# Resend (for order confirmation emails — https://resend.com, free tier: 100/day)
# Sign up, verify artspire.in domain (or use their shared sandbox domain for testing),
# then create an API key here: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
