# Supabase (REQUIRED for local dev and Vercel)
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (optional, defaults to https://theartspire.com)
# This drives canonical URLs, sitemap, robots.txt, OG/Twitter tags and schema.org.
VITE_SITE_URL=https://theartspire.com

# Active store currency (optional, defaults to INR). One of:
# INR, USD, GBP, AED, SAR, QAR, KWD. See src/lib/currency.ts.
# WARNING: setting a non-INR value only works once Razorpay International is
# activated AND products have per-currency prices. Do not change casually.
VITE_ACTIVE_CURRENCY=INR

# Razorpay (Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay webhook secret (Dashboard → Settings → Webhooks → create a webhook
# pointing to https://<your-domain>/api/webhooks/razorpay, subscribe to payment.captured).
# This is DIFFERENT from RAZORPAY_KEY_SECRET.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Supabase service_role key (Settings → API → service_role, SECRET — never expose client-side)
# Required for server-side payment confirmation (bypasses RLS safely after signature verification)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (for order confirmation emails — https://resend.com, free tier: 100/day)
# Sign up, verify your theartspire.com domain (or use their shared sandbox domain for testing),
# then create an API key here: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
